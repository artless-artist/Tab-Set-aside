{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.1.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "zh-CN",
  "icons": {
    "48": "icons/icon-48-dark.svg",
    "96": "icons/icon-48-dark.svg",
    "128": "icons/icon-48-dark.svg"
  },
  "action": {
    "default_icon": {
      "48": "icons/icon-48-dark.svg",
      "96": "icons/icon-48-dark.svg"
    },
    "default_popup": "popup.html",
    "default_title": "__MSG_pageActionTitle__",
    "theme_icons": [
      { "light": "icons/icon-48-light.svg", "dark": "icons/icon-48-dark.svg", "size": 48 },
      { "light": "icons/icon-48-light.svg", "dark": "icons/icon-48-dark.svg", "size": 96 }
    ]
  },
  "page_action": {
    "default_icon": {
      "48": "icons/icon-48-dark.svg",
      "96": "icons/icon-48-dark.svg"
    },
    "default_title": "__MSG_pageActionTitle__"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "tabs",
    "storage",
    "contextualIdentities",
    "cookies"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "Tab-Set-aside@artlessist",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}